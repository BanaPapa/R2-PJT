datasource db {
  provider = "sqlite"
  url      = "file:./kb_data.db"
}

generator client {
  provider = "prisma-client-js"
}

model WeeklyData {
  id             Int      @id @default(autoincrement())
  date           String   // YYYY-MM-DD
  region         String
  saleChange     Float?   // 매매증감 (%)
  jeonseChange   Float?   // 전세증감 (%)
  saleIndex      Float?   // 매매지수
  jeonseIndex    Float?   // 전세지수
  buyerAdvantage Float?   // 매수우위지수
  saleActivity   Float?   // 매매거래활발지수
  jeonseSupply   Float?   // 전세수급지수
  jeonseActivity Float?   // 전세거래활발지수
  @@unique([date, region])
  @@index([region, date])
  @@map("weekly_data")
}

model MonthlyData {
  id             Int      @id @default(autoincrement())
  date           String   // YYYY-MM (or YYYY-MM-DD for first of month)
  region         String
  dataType       String   // "housing" | "officetel"
  saleChange     Float?
  jeonseChange   Float?
  saleIndex      Float?
  jeonseIndex    Float?
  buyerAdvantage Float?
  saleActivity   Float?
  jeonseSupply   Float?
  jeonseActivity Float?
  @@unique([date, region, dataType])
  @@index([region, date])
  @@map("monthly_data")
}

model CollectionLog {
  id          Int      @id @default(autoincrement())
  dataType    String   // "weekly" | "monthly-housing" | "monthly-officetel"
  fileName    String
  status      String   // "success" | "failed" | "processing"
  recordCount Int?
  errorMsg    String?
  createdAt   DateTime @default(now())
  @@map("collection_logs")
}
