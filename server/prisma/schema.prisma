datasource db {
  provider = "sqlite"
  url      = "file:./kb_data.db"
}

generator client {
  provider = "prisma-client-js"
}

model WeeklyData {
  id             Int      @id @default(autoincrement())
  date           String   // YYYY-MM-DD
  region         String
  saleChange     Float?   // 매매증감 (%)
  jeonseChange   Float?   // 전세증감 (%)
  saleIndex      Float?   // 매매지수
  jeonseIndex    Float?   // 전세지수
  buyerAdvantage Float?   // 매수우위지수
  saleActivity   Float?   // 매매거래활발지수
  jeonseSupply   Float?   // 전세수급지수
  jeonseActivity Float?   // 전세거래활발지수
  @@unique([date, region])
  @@index([region, date])
  @@map("weekly_data")
}

model MonthlyData {
  id                 Int     @id @default(autoincrement())
  date               String  // YYYY-MM
  regionPath         String  // 계층 고유 식별자, 예: "전국>경기도>수원시>장안구"
  region             String  // leaf 표시명, 예: "장안구"
  level              Int     // 1=전국 … 깊을수록 큼
  parentPath         String? // 상위 regionPath (폴백용)
  saleAptIndex       Float?  // 2.매매APT - 아파트 매매가격지수
  jeonseAptIndex     Float?  // 6.전세APT - 아파트 전세가격지수
  aptSaleJeonseRatio Float?  // 28.아파트매매전세비 (%)
  aptAvgSalePerM2    Float?  // 47.㎡당아파트평균매매 (만원/㎡)
  aptAvgJeonsePerM2  Float?  // 48.㎡당아파트평균전세 (만원/㎡)
  @@unique([date, regionPath])
  @@index([regionPath, date])
  @@map("monthly_data")
}

model CollectionLog {
  id          Int      @id @default(autoincrement())
  dataType    String   // "weekly" | "monthly-housing" | "monthly-officetel"
  fileName    String
  status      String   // "success" | "failed" | "processing"
  recordCount Int?
  errorMsg    String?
  createdAt   DateTime @default(now())
  @@map("collection_logs")
}
